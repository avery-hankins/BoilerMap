# BoilerMap Backend Environment Configuration
# Copy this file to .env and update with your values

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL="mysql://root:<PASSWORD>@localhost:3306/BoilerMapDB"
# For Docker Compose MySQL:
# DATABASE_URL="mysql://root:boilermap_password@localhost:3306/BoilerMapDB"

# ===========================================
# Email Configuration (Gmail)
# ===========================================
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
# Note: Use Gmail App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords

# ===========================================
# Authentication
# ===========================================
JWT_SECRET=your_random_secret_key_here
# Generate a secure secret: openssl rand -base64 32

# ===========================================
# Server Configuration
# ===========================================
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# ===========================================
# AWS S3 / LocalStack Configuration
# ===========================================
# For LocalStack (local development)
S3_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET_NAME=boilermap-images

# For Production AWS S3 (uncomment and configure)
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# S3_BUCKET_NAME=your-production-bucket
